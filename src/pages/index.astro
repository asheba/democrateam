---
import Base from '../layouts/Base.astro';
import CandidateGrid from '../components/CandidateGrid';
import { candidates } from '../lib/candidates';
import { t } from '../i18n';

// Static (prerendered) — full candidate data ships in the HTML for speed and AI ingestion.
---

<Base>
  <div class="container">
    <div class="page-head">
      <h1>{t.home.heading}</h1>
      <p>{t.home.intro}</p>
    </div>
    <CandidateGrid candidates={candidates} client:load />
  </div>
</Base>
