---
import Base from '../layouts/Base.astro';
import CandidateGrid from '../components/CandidateGrid';
import { candidates, LINK_ORDER } from '../lib/candidates';
import { abs } from '../lib/site';
import { t } from '../i18n';

// Static (SSG): served as a CDN-cached HTML file. The once-a-day reshuffle at
// Israel midnight happens client-side inside CandidateGrid, so the page stays static.

// The visible cards hydrate client-side, so we also emit a schema.org ItemList
// of every candidate into the HTML for machine/LLM ingestion. Canonical order
// here is stable and machine-friendly (the on-page rotation is cosmetic only).
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: t.home.heading,
  numberOfItems: candidates.length,
  itemListElement: candidates.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Person',
      name: c.name,
      ...(c.title ? { jobTitle: c.title } : {}),
      image: abs(c.photo),
      description: c.bio,
      sameAs: LINK_ORDER.map((k) => c.links[k]).filter(Boolean),
    },
  })),
};

// Absolute URL of the LLM-readable candidate corpus to paste into an AI chat.
const candidatesMdUrl = abs('/candidates.md');
---

<Base>
  <Fragment slot="head">
    <link rel="alternate" type="text/markdown" href="/candidates.md" />
    <link rel="alternate" type="application/json" href="/candidates.json" />
    <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
    {/* Rotate the grid once per Israel-day via CSS `order`, applied before first
        paint so there is no flicker/layout shift and the page stays static (SSG).
        Vanilla mirror of src/lib/daily-order.ts — must stay in sync with it. */}
    <script is:inline define:vars={{ candidateIds: candidates.map((c) => c.id) }}>
      (function () {
        var dayKey = new Intl.DateTimeFormat('en-CA', {
          timeZone: 'Asia/Jerusalem',
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        }).format(new Date());
        var h = 5381;
        for (var i = 0; i < dayKey.length; i++) {
          h = (Math.imul(h, 33) ^ dayKey.charCodeAt(i)) >>> 0;
        }
        var a = h >>> 0;
        function rand() {
          a |= 0;
          a = (a + 0x6d2b79f5) | 0;
          var t = Math.imul(a ^ (a >>> 15), 1 | a);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        }
        var ids = candidateIds.slice();
        for (var j = ids.length - 1; j > 0; j--) {
          var k = Math.floor(rand() * (j + 1));
          var tmp = ids[j];
          ids[j] = ids[k];
          ids[k] = tmp;
        }
        var css = ids
          .map(function (id, pos) {
            return '.cand-grid [data-id="' + id + '"]{order:' + pos + '}';
          })
          .join('');
        var style = document.createElement('style');
        style.id = 'daily-order';
        style.textContent = css;
        document.head.appendChild(style);
      })();
    </script>
  </Fragment>
  <div class="container">
    <div class="page-head">
      <h1>{t.home.heading}</h1>
      <div class="ai-link">
        <button class="btn btn-ghost btn-sm" type="button" data-copy-ai={candidatesMdUrl} data-copied-label={t.ai.copied}>
          {t.ai.copyLink}
        </button>
        <span class="ai-link-hint">{t.ai.hint}</span>
      </div>
    </div>
    <CandidateGrid candidates={candidates} client:load />
  </div>
  <script>import '../scripts/copy-ai-link';</script>
</Base>
