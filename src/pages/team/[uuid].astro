---
import Base from '../../layouts/Base.astro';
import TeamGrid from '../../components/TeamGrid';
import { getCandidate, LINK_ORDER } from '../../lib/candidates';
import { getTeam } from '../../lib/db';
import { abs } from '../../lib/site';
import { t, fmt } from '../../i18n';
import './team.css';

// On-demand rendered: each uuid yields a different combination of cards + texts.
export const prerender = false;

const { uuid } = Astro.params;
const team = uuid ? await getTeam(uuid) : null;

if (!team) {
  Astro.response.status = 404;
}

// Resolve full candidate data for each saved selection, preserving saved order.
const rows = team
  ? team.selections
      .map((sel) => ({ candidate: getCandidate(sel.candidateId), explanation: sel.explanation }))
      .filter((r): r is { candidate: NonNullable<ReturnType<typeof getCandidate>>; explanation: string } =>
        Boolean(r.candidate),
      )
  : [];

// 1–2 letter fallback for the round avatar when there's no profile photo.
const initials = team
  ? team.voterName
      .trim()
      .split(/\s+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((w) => Array.from(w)[0] ?? '')
      .join('')
  : '';

// LLM-readable variants of this team page (public but unlisted).
const mdPath = `${Astro.url.pathname}.md`;
const jsonPath = `${Astro.url.pathname}.json`;

// Per-team OG/social description: prefer the voter's own summary, else list the picks.
const teamDescription = team
  ? team.summary?.trim() || rows.map((r) => r.candidate.name).join(', ')
  : undefined;

// schema.org ItemList of the selected candidates, mirroring the visible cards.
const teamItemList = team
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: fmt(t.team.heading, { name: team.voterName }),
      numberOfItems: rows.length,
      itemListElement: rows.map((r, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'Person',
          name: r.candidate.name,
          ...(r.candidate.title ? { jobTitle: r.candidate.title } : {}),
          image: abs(r.candidate.photo),
          description: r.candidate.bio,
          sameAs: LINK_ORDER.map((k) => r.candidate.links[k]).filter(Boolean),
        },
      })),
    }
  : null;
---

{
  team ? (
    <Base title={fmt(t.team.heading, { name: team.voterName })} description={teamDescription}>
      <Fragment slot="head">
        <meta name="robots" content="noindex" />
        <link rel="alternate" type="text/markdown" href={mdPath} />
        <link rel="alternate" type="application/json" href={jsonPath} />
        <script type="application/ld+json" set:html={JSON.stringify(teamItemList)} />
      </Fragment>
      <div class="container">
        <div class="team-head">
          <div class="team-identity">
            <div class="team-avatar-wrap">
              {team.voterImage ? (
                <img class="team-avatar" src={team.voterImage} alt={team.voterName} referrerpolicy="no-referrer" />
              ) : (
                <span class="team-avatar team-avatar-initials" aria-hidden="true">{initials}</span>
              )}
              {team.verified ? (
                <span class="team-avatar-check" title={t.team.verifiedBadge} aria-label={t.team.verifiedBadge}>✓</span>
              ) : null}
            </div>
            <span class="team-name">{team.voterName}</span>
          </div>
          <div class="team-head-text">
            <h1>{t.team.myTeam}</h1>
            {team.summary ? (
              <div class="team-summary">
                <h2>{t.team.summaryHeading}</h2>
                <p>{team.summary}</p>
              </div>
            ) : null}
          </div>
        </div>

        <TeamGrid rows={rows} client:load />

        <div class="team-cta">
          <a class="btn" href="/">{t.team.createOwn}</a>
        </div>
      </div>
    </Base>
  ) : (
    <Base title={t.team.notFoundTitle}>
      <Fragment slot="head">
        <meta name="robots" content="noindex" />
      </Fragment>
      <div class="container">
        <div class="team-notfound">
          <h1>{t.team.notFoundTitle}</h1>
          <p>{t.team.notFoundBody}</p>
          <a class="btn" href="/">{t.team.backHome}</a>
        </div>
      </div>
    </Base>
  )
}
