# Turso / libSQL connection.
# Leave both unset for local development — the app falls back to a local SQLite
# file (file:local.db) so the full flow works offline.
#
# For production (Vercel), set these to your Turso cloud database:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Better Auth.
# BETTER_AUTH_SECRET: min 32 chars — generate with: openssl rand -base64 32
# BETTER_AUTH_URL: base URL of the app (http://localhost:4321 in dev, prod URL live).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4321

# Public base URL of the deployed site (no trailing slash), e.g. https://example.com.
# Used for absolute URLs in canonical tags, JSON-LD, sitemap.xml, robots.txt and
# llms.txt. Falls back to http://localhost:4321 when unset.
PUBLIC_SITE_URL=http://localhost:4321

# Amplitude analytics.
# Public (client-side) API key for the Amplitude Browser SDK. Exposed to the
# browser, so it must use the PUBLIC_ prefix. When unset, analytics is disabled.
# Autocapture handles sessions and element (click) tracking automatically — no
# manual event logging is needed.
PUBLIC_AMPLITUDE_API_KEY=

# Social login credentials (create an OAuth app in the Google Cloud console).
# Authorized redirect URI:
#   {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
